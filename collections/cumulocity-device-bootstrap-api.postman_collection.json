  "info": {
    "_postman_id": "49408406-7423-401f-9fef-fdf97410381a",
    "name": "Cumulocity Device Bootstrap API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Zero-touch device onboarding flow. A factory-bootstrapped device authenticates with a shared bootstrap\nuser, polls /devicecontrol/deviceCredentials with its external ID, and receives back tenant-scoped\ncredentials once an admin accepts the registration request in the Device Management UI.\n",
      "type": "text/plain"
    }
  }
