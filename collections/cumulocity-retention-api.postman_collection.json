  "info": {
    "_postman_id": "be5402ff-ec24-4a44-aee7-477d8e4041eb",
    "name": "Cumulocity Retention Rules API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Define retention rules that automatically delete measurements, events, alarms, audit records, and\noperations older than a configured age. Rules can be scoped by data type, source, and fragment.\nDefault policies apply per-plan; Enterprise tenants can override.\n",
