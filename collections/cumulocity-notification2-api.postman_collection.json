    "name": "Cumulocity Notification 2.0 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "High-throughput, persistent, ordered notification streaming for production microservices. Subscribers\ndeclare typed subscriptions (managed object, measurements, events, alarms, operations), exchange them\nfor short-lived JWT tokens, and consume via WebSocket. Survives subscriber outages by buffering messages\non the server.\n",
      "type": "text/plain"
    }
  }
