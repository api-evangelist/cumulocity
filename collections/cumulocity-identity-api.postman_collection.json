  "info": {
    "_postman_id": "806b9173-03cb-4741-9fae-38ed2de2a8d5",
    "name": "Cumulocity Identity API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Link external identifiers (IMEI, serial number, MAC, ICCID, c8y_Serial, etc.) to Cumulocity managed\nobject IDs. The Identity API is the primary lookup table used by device bootstrap, MQTT auto-registration,\nand any integration translating provider-specific IDs to Cumulocity IDs.\n",
      "type": "text/plain"
    }
